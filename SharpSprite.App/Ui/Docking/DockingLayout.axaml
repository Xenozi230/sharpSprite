<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:docking="clr-namespace:SharpSprite.App.Ui.Docking"
             x:Class="SharpSprite.App.Ui.Docking.DockingLayout">

  <!-- Grid principal avec les positions de dock -->
  <Grid RowDefinitions="*" ColumnDefinitions="50, *, 200" Background="#2d2d2d">
    
    <!-- Panneaux à GAUCHE -->
    <Border Grid.Column="0" 
            Background="#2d2d2d" 
            BorderBrush="#444444" 
            BorderThickness="0,0,1,0">
      <StackPanel Orientation="Vertical" x:Name="LeftPanel"/>
    </Border>

    <!-- Panneau CENTRAL (Canvas) -->
    <Border Grid.Column="1" Background="#181818" ClipToBounds="True">
      <ContentControl x:Name="CentralContent"/>
    </Border>

    <!-- Panneaux à DROITE -->
    <Border Grid.Column="2" 
            Background="#2d2d2d" 
            BorderBrush="#444444"
            BorderThickness="1,0,0,0">
      <StackPanel Orientation="Vertical" x:Name="RightPanel"/>
    </Border>

  </Grid>

</UserControl>
