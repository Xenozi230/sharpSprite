<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SharpSprite.App.ViewModels"
             x:Class="SharpSprite.App.Controls.ToolbarControl"
             x:DataType="vm:ToolbarViewModel"
			 Width="36">
	
	<UserControl.Styles>

		<!-- Base tool button -->
		<Style Selector="Button.tool-btn">
			<Setter Property="Width" Value="30"/>
			<Setter Property="Height" Value="30"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Margin" Value="3,2,3,0"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="CornerRadius" Value="2"/>
		</Style>

		<Style Selector="Button.tool-btn:pointerover">
			<Setter Property="Background" Value="#3a3a3a"/>
			<Setter Property="BorderBrush" Value="#555"/>
		</Style>

		<Style Selector="Button.tool-btn.active">
			<Setter Property="Background" Value="#1a6fb5"/>
			<Setter Property="BorderBrush" Value="#4a9fe8"/>
		</Style>

		<Style Selector="Button.tool-btn.active:pointerover">
			<Setter Property="Background" Value="#2279c4"/>
		</Style>

		<!-- Tool icon text (pixel-font glyph or unicode) -->
		<Style Selector="TextBlock.tool-icon">
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="Foreground" Value="#cccccc"/>
			<Setter Property="HorizontalAlignment" Value="Center"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
		</Style>

		<Style Selector="Button.tool-btn.active TextBlock.tool-icon">
			<Setter Property="Foreground" Value="White"/>
		</Style>

		<!-- Separator line -->
		<Style Selector="Border.tool-sep">
			<Setter Property="Height" Value="1"/>
			<Setter Property="Margin" Value="4,4,4,2"/>
			<Setter Property="Background" Value="#3a3a3a"/>
		</Style>

	</UserControl.Styles>

	<ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
		<StackPanel Spacing="0" Background="#252525">

			<!-- SELECTION -->
			<Button Classes="tool-btn"
					Classes.active="{Binding IsSelectionActive}"
					Command="{Binding SelectSelectionCommand}"
					ToolTip.Tip="Marquee Selection (M)">
				<TextBlock Classes="tool-icon" Text="⬚"/>
			</Button>

			<Border Classes="tool-sep"/>

			<!-- PENCIL -->
			<Button Classes="tool-btn"
					Classes.active="{Binding IsPencilActive}"
					Command="{Binding SelectPencilCommand}"
					ToolTip.Tip="Pencil (P)">
				<Canvas Width="16" Height="16">
					<Line StartPoint="2,13" EndPoint="12,3"
						  Stroke="#cccccc" StrokeThickness="1.5"/>
					<Line StartPoint="12,3" EndPoint="14,5"
						  Stroke="#cccccc" StrokeThickness="1.5"/>
					<Line StartPoint="14,5" EndPoint="4,15"
						  Stroke="#cccccc" StrokeThickness="1.5"/>
					<Line StartPoint="2,13" EndPoint="4,15"
						  Stroke="#cccccc" StrokeThickness="1.5"/>
					<Rectangle Canvas.Left="1" Canvas.Top="13" Width="3" Height="2"
							   Fill="#cccccc" Opacity="0.5"/>
				</Canvas>
			</Button>

			<!-- ERASER -->
			<Button Classes="tool-btn"
					Classes.active="{Binding IsEraserActive}"
					Command="{Binding SelectEraserCommand}"
					ToolTip.Tip="Eraser (E)">
				<Canvas Width="16" Height="16">
					<Rectangle Canvas.Left="1" Canvas.Top="7" Width="14" Height="7"
							   Fill="#CC5555" Stroke="#888" StrokeThickness="1" RadiusX="1" RadiusY="1"/>
					<Rectangle Canvas.Left="7" Canvas.Top="7" Width="8" Height="7"
							   Fill="#EE7777" RadiusX="1" RadiusY="1"/>
					<Line StartPoint="1,14" EndPoint="8,14"
						  Stroke="#cccccc" StrokeThickness="1.5"/>
				</Canvas>
			</Button>

			<!-- FILL BUCKET -->
			<Button Classes="tool-btn"
					Classes.active="{Binding IsFillActive}"
					Command="{Binding SelectFillCommand}"
					ToolTip.Tip="Paint Bucket (G)">
				<TextBlock Classes="tool-icon" Text="🪣" FontSize="13"/>
			</Button>

			<!-- EYEDROPPER -->
			<Button Classes="tool-btn"
					Classes.active="{Binding IsEyedropperActive}"
					Command="{Binding SelectEyedropperCommand}"
					ToolTip.Tip="Eyedropper (I)">
				<Canvas Width="16" Height="16">
					<Line StartPoint="10,2" EndPoint="14,6"
						  Stroke="#aaaaff" StrokeThickness="1.5"/>
					<Line StartPoint="3,13" EndPoint="10,2"
						  Stroke="#cccccc" StrokeThickness="1.5"/>
					<Line StartPoint="3,13" EndPoint="5,15"
						  Stroke="#cccccc" StrokeThickness="1.5"/>
					<Ellipse Canvas.Left="1" Canvas.Top="12" Width="4" Height="4"
							 Fill="#4488ee"/>
				</Canvas>
			</Button>

			<Border Classes="tool-sep"/>

			<!-- LINE -->
			<Button Classes="tool-btn"
					Classes.active="{Binding IsLineActive}"
					Command="{Binding SelectLineCommand}"
					ToolTip.Tip="Line (L)">
				<Canvas Width="16" Height="16">
					<Line StartPoint="2,14" EndPoint="14,2"
						  Stroke="#cccccc" StrokeThickness="1.5"/>
				</Canvas>
			</Button>

			<!-- RECTANGLE -->
			<Button Classes="tool-btn"
					Classes.active="{Binding IsRectangleActive}"
					Command="{Binding SelectRectangleCommand}"
					ToolTip.Tip="Rectangle (R)">
				<Canvas Width="16" Height="16">
					<Rectangle Canvas.Left="2" Canvas.Top="3" Width="12" Height="9"
							   Stroke="#cccccc" StrokeThickness="1.5" Fill="Transparent"/>
				</Canvas>
			</Button>

			<!-- ELLIPSE -->
			<Button Classes="tool-btn"
					Classes.active="{Binding IsEllipseActive}"
					Command="{Binding SelectEllipseCommand}"
					ToolTip.Tip="Ellipse (O)">
				<Canvas Width="16" Height="16">
					<Ellipse Canvas.Left="2" Canvas.Top="3" Width="12" Height="10"
							 Stroke="#cccccc" StrokeThickness="1.5" Fill="Transparent"/>
				</Canvas>
			</Button>

			<Border Classes="tool-sep"/>

			<!-- ZOOM -->
			<Button Classes="tool-btn"
					Classes.active="{Binding IsZoomActive}"
					Command="{Binding SelectZoomCommand}"
					ToolTip.Tip="Zoom (Z)">
				<Canvas Width="16" Height="16">
					<Ellipse Canvas.Left="1" Canvas.Top="1" Width="10" Height="10"
							 Stroke="#cccccc" StrokeThickness="1.5" Fill="Transparent"/>
					<Line StartPoint="9,9" EndPoint="15,15"
						  Stroke="#cccccc" StrokeThickness="2"/>
					<Line StartPoint="4,6" EndPoint="8,6"
						  Stroke="#cccccc" StrokeThickness="1.5"/>
					<Line StartPoint="6,4" EndPoint="6,8"
						  Stroke="#cccccc" StrokeThickness="1.5"/>
				</Canvas>
			</Button>

			<!-- PAN / HAND -->
			<Button Classes="tool-btn"
					Classes.active="{Binding IsPanActive}"
					Command="{Binding SelectPanCommand}"
					ToolTip.Tip="Pan / Hand (H)">
				<TextBlock Classes="tool-icon" Text="✋" FontSize="13"/>
			</Button>

		</StackPanel>
	</ScrollViewer>
</UserControl>
